# Copiez ce fichier en ".env" et remplissez les valeurs réelles.

# --- Django ---
SECRET_KEY=change-moi-en-production-avec-une-cle-longue-et-aleatoire
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de données PostgreSQL (Supabase) ---
# IMPORTANT : ce n'est PAS la clé publique "sb_publishable_...".
# Allez dans Supabase -> Project Settings -> Database -> Connection string (URI)
# et copiez l'URL complète (elle contient le mot de passe de la base).
# Format : postgresql://postgres:VOTRE_MOT_DE_PASSE@db.oimzupgpfvyiyvmmabbg.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:VOTRE_MOT_DE_PASSE@db.oimzupgpfvyiyvmmabbg.supabase.co:5432/postgres

# --- Email (pour vérification de compte, notifications) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-adresse@example.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-application
DEFAULT_FROM_EMAIL=QUANTUM TECHNOLOGY <no-reply@quantum-technology.com>

# --- Redis (cache, Celery) ---
REDIS_URL=redis://localhost:6379/0
